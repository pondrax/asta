# --- App ---
BODY_LIMIT=Infinity
ORIGIN=http://127.0.0.1:3000
APP_SECRET=replace_with_random_32_chars

# --- Database ---
DATABASE_URL="postgres://user:password@host:port/db-name"

# --- BSrE e-Sign ---
ESIGN_URL=http://your-esign-host:8081
ESIGN_API_KEY="Basic base64_credentials"
ESIGN_VERIFY_URL=http://your-esign-host:8081
ESIGN_VERIFY_KEY="Basic base64_credentials"

# --- WhatsApp ---
WHATSAPP_HOST=http://your-whatsapp-host:3001
WHATSAPP_AUTH=your_whatsapp_auth_token

# --- Storage ---
STORAGE_PROVIDER="local"
# STORAGE_PROVIDER="vercel"
# BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# --- Rate Limiting ---
PUBLIC_MAX_CONCURRENT_REQUESTS=5
PUBLIC_MAX_RETRIES=5

# --- Cloudflare Turnstile ---
PUBLIC_TURNSTILE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# --- OpenID Connect (SSO) ---
OPENID_BASE_URL="https://your-sso-host"
OPENID_REALM=SSO-GOV
OPENID_CLIENT_ID=asta
OPENID_CLIENT_SECRET=your_openid_client_secret
OPENID_REDIRECT_URI=http://127.0.0.1:3000/auth/openid/callback
OPENID_SCOPE="openid email profile"

# --- TLS (dev only) ---
# NODE_TLS_REJECT_UNAUTHORIZED=0

# --- Healthcheck ---
TEST_URL=https://your-domain.com/healthcheck
TEST_COUNT=1000
TEST_DURATION=10

# --- Browser Automation ---
# BROWSER_EXECUTABLE_PATH="/Applications/Brave Browser.app/Contents/MacOS/Brave Browser"
BROWSER_REMOTE_DEBUG_URL="http://your-host:9222"

# --- BSrE Portal ---
PORTAL_BSRE_USERNAME=your_username
PORTAL_BSRE_PASSWORD=your_password
PORTAL_OTP_AUTH="//totp/BeID:username?secret=YOUR_BASE32_SECRET&issuer=BeID"

# --- 9Router AI (default: http://localhost:20128/v1) ---
# AI_URL=http://localhost:20128/v1/chat/completions
# AI_KEY=your_9router_api_key
# AI_MODEL=oc/big-pickle
